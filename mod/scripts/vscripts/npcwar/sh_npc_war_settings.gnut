	AddPrivateMatchModeSettingArbitrary( NPCWAR_SETTINGS_CATEGORY_GENERAL, NPCWAR_PLAYER_PILOT_DEATH_SCORE_VAR, string( NPCWAR_PLAYER_PILOT_DEATH_SCORE_DEFAULT ), "Player Pilot Death Score" )
