	AddPrivateMatchModeSettingEnum( NPCWAR_SETTINGS_CATEGORY_GENERAL, NPCWAR_GRUNT_MOVEMENT_VAR, [ "#SETTING_DISABLED", "#SETTING_ENABLED" ], "0", "Grunt Movement" )
	AddPrivateMatchModeSettingEnum( NPCWAR_SETTINGS_CATEGORY_GENERAL, NPCWAR_CALLABLE_TITANS_VAR, [ "#SETTING_DISABLED", "Vanilla", "Post-Titan Threshold" ], "2", "Titan Availability" )
	AddPrivateMatchModeSettingEnum( NPCWAR_SETTINGS_CATEGORY_GENERAL, NPCWAR_BOOST_MODE_VAR, [ "#SETTING_DISABLED", "Vanilla", "Post-Titan Threshold" ], "1", "Boost Availability" )
